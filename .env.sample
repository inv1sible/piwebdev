SECRET_KEY=change-this-long-random-django-secret
DEBUG=0
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:3142

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-this-long-random-admin-password

PROJECTS_ROOT=/var/opt
DEFAULT_PI_PROVIDER=openai-codex
DEFAULT_PI_MODEL=gpt-5.5
DEFAULT_PI_THINKING=minimal

# Writable provider/model catalog — edit via the Providers page in the web UI.
# Set to a path inside the project volume so both Docker and pi-bridge can read it.
# If unset, the read-only ~/.pi/agent/models.json is used (and the Providers editor is disabled).
# PI_MODELS_JSON_PATH=/var/opt/piwebdev/models.json
